/* pages/home/home.wxss - 喜茶清爽极简・大留白 */

/* ========== Hero Section ========== */
.hero-section {
  width: 100%;
  position: relative;
  overflow: hidden;
  background: #FFFFFF;
}

.hero-image {
  width: 100%;
  height: 640rpx;
  position: relative;
  background: #FFFFFF;
}

.hero-img {
  width: 100%;
  height: 100%;
  display: block;
}

.hero-image::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: transparent;
}

.hero-content {
  position: relative;
  z-index: 2;
  padding: 0 80rpx 100rpx;
  margin-top: -80rpx;
  text-align: center;
}

.hero-tag {
  font-size: 24rpx;
  letter-spacing: 8rpx;
  color: #888888;
  margin-bottom: 36rpx;
  font-weight: 400;
  font-family: Georgia, 'Times New Roman', serif;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 300;
  color: #333333;
  letter-spacing: 16rpx;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.hero-subtitle {
  font-size: 30rpx;
  color: #666666;
  letter-spacing: 3rpx;
  margin-bottom: 70rpx;
  font-weight: 400;
}

.hero-divider {
  width: 24rpx;
  height: 1rpx;
  background: #E0E0E0;
  margin: 0 auto 70rpx;
}

.hero-action {
  display: inline-block;
  color: #7BAF8A;
  font-size: 30rpx;
  letter-spacing: 4rpx;
  font-weight: 400;
  transition: color 0.3s ease;
}

.hero-action:active {
  color: #5E8A6E;
}

/* ========== Brand Statement - 书刊居中留白 ========== */
.brand-statement {
  position: relative;
  padding: 160rpx 120rpx;
  text-align: center;
  background: #FFFFFF;
}

.statement-mark {
  font-size: 60rpx;
  color: #E0E0E0;
  font-weight: 300;
  line-height: 1;
  margin-bottom: -20rpx;
  font-family: Georgia, 'Times New Roman', serif;
}

.statement-text {
  display: block;
  font-size: 32rpx;
  color: #666666;
  line-height: 2.8;
  letter-spacing: 2rpx;
  font-weight: 400;
}

/* ========== Featured Section ========== */
.featured-section {
  background: #FFFFFF;
  padding: 120rpx 0;
}

.featured-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 80rpx;
  margin-bottom: 80rpx;
}

.featured-label {
  font-size: 32rpx;
  font-weight: 400;
  color: #666666;
  letter-spacing: 8rpx;
  margin: 0 30rpx;
}

.featured-line {
  width: 24rpx;
  height: 1rpx;
  background: #E0E0E0;
}

.featured-card {
  width: 600rpx;
  margin: 0 auto;
  background: #F8F8F8;
  border-radius: 8rpx;
  overflow: hidden;
  transition: transform 0.3s ease;
}

.featured-card:active {
  transform: scale(0.99);
}

.featured-image-wrap {
  width: 100%;
  height: 380rpx;
  position: relative;
  background: #F8F8F8;
}

.featured-image {
  width: 100%;
  height: 100%;
  display: block;
}

.featured-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F8F8F8;
}

.placeholder-char {
  font-size: 72rpx;
  color: #E0E0E0;
  font-weight: 300;
}

.featured-info {
  padding: 60rpx 50rpx;
  text-align: center;
}

.featured-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: #F2F2F2;
  color: #666666;
  font-size: 24rpx;
  letter-spacing: 3rpx;
  border-radius: 2rpx;
  margin-bottom: 28rpx;
  font-weight: 400;
}

.featured-name {
  font-size: 36rpx;
  font-weight: 400;
  color: #333333;
  margin-bottom: 10rpx;
  letter-spacing: 4rpx;
}

.featured-category {
  font-size: 28rpx;
  color: #888888;
  margin-bottom: 28rpx;
  letter-spacing: 2rpx;
  font-weight: 400;
}

.featured-desc {
  font-size: 30rpx;
  color: #666666;
  line-height: 2.2;
  margin-bottom: 48rpx;
  font-weight: 400;
}

.featured-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 80rpx;
  padding-top: 36rpx;
  border-top: 1rpx solid #EEEEEE;
}

.featured-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #444444;
}

.featured-action {
  display: flex;
  align-items: center;
  color: #7BAF8A;
  font-size: 30rpx;
  letter-spacing: 2rpx;
  font-weight: 400;
}

.action-text {
  margin-right: 8rpx;
}

.arrow {
  font-size: 28rpx;
  transition: transform 0.3s ease;
}

.featured-card:active .arrow {
  transform: translateX(4rpx);
}

/* ========== Bottom Info ========== */
.bottom-info {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  background: #FFFFFF;
}

.info-item {
  text-align: center;
  padding: 0 60rpx;
}

.info-label {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.info-desc {
  display: block;
  font-size: 26rpx;
  color: #888888;
  letter-spacing: 2rpx;
  font-weight: 400;
}

.info-divider {
  width: 1rpx;
  height: 36rpx;
  background: #EEEEEE;
}

/* ========== Bottom Spacer ========== */
.bottom-spacer {
  height: 200rpx;
}
