/* pages/home/home.wxss */

/* Hero Section */
.hero-section {
  width: 100%;
  height: 900rpx;
  position: relative;
  background: linear-gradient(135deg, #5B7744 0%, #3D5232 30%, #2A3B24 60%, #1A2818 100%);
  overflow: hidden;
}

.hero-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse at 70% 30%, rgba(139, 105, 20, 0.15) 0%, transparent 60%),
              radial-gradient(ellipse at 30% 70%, rgba(91, 119, 68, 0.1) 0%, transparent 50%);
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-content {
  text-align: center;
  color: #ffffff;
  padding: 40rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  letter-spacing: 12rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 80rpx;
  font-weight: bold;
  letter-spacing: 20rpx;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.hero-desc {
  font-size: 30rpx;
  letter-spacing: 6rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 40rpx;
}

.hero-divider {
  width: 60rpx;
  height: 2rpx;
  background: rgba(196, 168, 98, 0.6);
  margin: 0 auto 40rpx;
}

.hero-action {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 4rpx;
}

.arrow-down {
  margin-left: 8rpx;
  font-size: 22rpx;
}

/* Section Header (shared) */
.section-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx 40rpx;
}

.section-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  letter-spacing: 4rpx;
  margin: 0 24rpx;
}

.section-line {
  width: 60rpx;
  height: 2rpx;
  background: #C4A862;
}

/* Story Section */
.story-section {
  background: #ffffff;
  padding-bottom: 40rpx;
}

.story-content {
  padding: 0 50rpx;
}

.story-text-block {
  text-align: center;
  margin-bottom: 50rpx;
}

.story-lead {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  line-height: 1.8;
  margin-bottom: 24rpx;
}

.story-body {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 2;
  text-align: justify;
}

.story-highlight {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 0;
}

.highlight-card {
  text-align: center;
  flex: 1;
}

.highlight-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B6914, #C4A862);
  margin: 0 auto 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.highlight-icon.icon-mountain::after {
  content: '';
  width: 24rpx;
  height: 24rpx;
  border-left: 4rpx solid #fff;
  border-top: 4rpx solid #fff;
  transform: rotate(45deg);
  margin-bottom: 12rpx;
}

.highlight-icon.icon-leaf::after {
  content: '';
  width: 20rpx;
  height: 28rpx;
  border: 3rpx solid #fff;
  border-radius: 0 50% 50% 50%;
  transform: rotate(45deg);
}

.highlight-icon.icon-hand::after {
  content: '';
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid #fff;
  border-radius: 50%;
}

.highlight-num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #8B6914;
  margin-bottom: 4rpx;
}

.highlight-label {
  display: block;
  font-size: 26rpx;
  color: #999999;
}

/* Featured Section */
.featured-section {
  background: #FAFAFA;
  padding-bottom: 40rpx;
}

.featured-item {
  display: flex;
  padding: 30rpx 40rpx;
  align-items: center;
}

.featured-reverse {
  flex-direction: row-reverse;
}

.featured-img {
  width: 300rpx;
  height: 300rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  position: relative;
}

.featured-img-1 {
  background: linear-gradient(135deg, #A8C090, #7FA068, #5B7744);
}

.featured-img-2 {
  background: linear-gradient(135deg, #8B6914, #6B5010, #4A380A);
}

.featured-info {
  flex: 1;
  padding: 20rpx;
}

.featured-reverse .featured-info {
  text-align: right;
}

.featured-name {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.featured-subtitle {
  display: block;
  font-size: 26rpx;
  color: #8B6914;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.featured-desc {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.featured-price-row {
  display: flex;
  align-items: baseline;
}

.featured-reverse .featured-price-row {
  justify-content: flex-end;
}

.featured-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #E54D42;
}

.featured-unit {
  font-size: 24rpx;
  color: #999999;
  margin-left: 4rpx;
}

/* Why Choose Us Section */
.why-section {
  background: #ffffff;
  padding-bottom: 40rpx;
}

.why-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 30rpx;
}

.why-item {
  width: 50%;
  padding: 20rpx;
  text-align: center;
}

.why-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin: 0 auto 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-organic {
  background: rgba(91, 119, 68, 0.1);
  border: 2rpx solid rgba(91, 119, 68, 0.3);
}

.icon-handpick {
  background: rgba(139, 105, 20, 0.1);
  border: 2rpx solid rgba(139, 105, 20, 0.3);
}

.icon-craft {
  background: rgba(196, 168, 98, 0.1);
  border: 2rpx solid rgba(196, 168, 98, 0.3);
}

.icon-fresh {
  background: rgba(91, 119, 68, 0.1);
  border: 2rpx solid rgba(91, 119, 68, 0.3);
}

.icon-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #8B6914;
}

.why-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.why-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
  line-height: 1.5;
}

/* Best Sellers Section */
.bestseller-section {
  background: #FAFAFA;
  padding-bottom: 30rpx;
}

.bestseller-scroll {
  white-space: nowrap;
  padding: 0 30rpx;
}

.bestseller-list {
  display: inline-flex;
  padding: 10rpx 0;
}

.bestseller-item {
  width: 260rpx;
  margin-right: 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
}

.bestseller-img-wrap {
  position: relative;
  width: 260rpx;
  height: 260rpx;
}

.bestseller-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #E8DCC8, #D4C4A8);
  display: flex;
  align-items: center;
  justify-content: center;
}

.bestseller-img-real {
  width: 100%;
  height: 100%;
  display: block;
}

.placeholder-text {
  font-size: 60rpx;
  color: rgba(139, 105, 20, 0.3);
  font-weight: bold;
}

.bestseller-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background: #E54D42;
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.bestseller-info {
  padding: 16rpx;
}

.bestseller-name {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bestseller-desc-text {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bestseller-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bestseller-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #E54D42;
}

.bestseller-add {
  width: 44rpx;
  height: 44rpx;
  background: #8B6914;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
}

/* View All Button */
.view-all-btn {
  margin: 30rpx 60rpx 0;
  text-align: center;
  padding: 20rpx;
  border: 2rpx solid #8B6914;
  border-radius: 40rpx;
  color: #8B6914;
  font-size: 26rpx;
  letter-spacing: 4rpx;
}

/* Philosophy Section */
.philosophy-section {
  position: relative;
  padding: 80rpx 50rpx;
  overflow: hidden;
}

.philosophy-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FAF8F3, #F5F0E6);
}

.philosophy-content {
  position: relative;
  text-align: center;
}

.philosophy-mark {
  font-size: 100rpx;
  color: rgba(139, 105, 20, 0.15);
  font-weight: bold;
  line-height: 1;
  margin-bottom: -40rpx;
}

.philosophy-text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 2.2;
  font-style: italic;
  letter-spacing: 2rpx;
}

.philosophy-author {
  margin-top: 30rpx;
  font-size: 26rpx;
  color: #8B6914;
  letter-spacing: 4rpx;
}

/* Bottom Spacer */
.bottom-spacer {
  height: 120rpx;
}
