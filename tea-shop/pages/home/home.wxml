<!-- pages/home/home.wxml -->
<view class="home-page">

  <!-- Hero Section - 极简居中对称留白 -->
  <view class="hero-section">
    <view class="hero-image">
      <image class="hero-img" src="/images/tea-hero.jpg" mode="aspectFill"></image>
    </view>
    <view class="hero-content">
      <view class="hero-tag">PREMIUM</view>
      <view class="hero-title">红茶·艺术</view>
      <view class="hero-subtitle">懂茶的人，都懂这一杯</view>
      <view class="hero-divider"></view>
      <view class="hero-action" bindtap="goToCategory">
        <text>立即选购</text>
      </view>
    </view>
  </view>

  <!-- Brand Statement - 居中对称 -->
  <view class="brand-statement">
    <view class="statement-mark">"</view>
    <text class="statement-text">不是所有红茶，都值得等待。我们用时间换品质，让每一杯茶，都成为时光的见证。</text>
  </view>

  <!-- Featured Product - 极简卡片 -->
  <view class="featured-section">
    <view class="featured-header">
      <text class="featured-label">匠心之作</text>
      <view class="featured-line"></view>
    </view>
    <view class="featured-card" bindtap="goToDetail" data-id="{{featuredProduct.id}}">
      <view class="featured-image-wrap">
        <image wx:if="{{featuredProduct.image}}" class="featured-image" src="{{featuredProduct.image}}" mode="aspectFill"></image>
        <view wx:else class="featured-placeholder">
          <text class="placeholder-char">{{featuredProduct.name[0]}}</text>
        </view>
      </view>
      <view class="featured-info">
        <view class="featured-tag">本期精选</view>
        <view class="featured-name">{{featuredProduct.name}}</view>
        <view class="featured-category">{{featuredProduct.category}}</view>
        <view class="featured-desc">{{featuredProduct.desc}}</view>
        <view class="featured-footer">
          <text class="featured-price">¥{{featuredProduct.price}}</text>
          <view class="featured-action">
            <text class="action-text">查看详情</text>
            <text class="arrow">→</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Bottom Info - 极简 -->
  <view class="bottom-info">
    <view class="info-item">
      <text class="info-label">1898</text>
      <text class="info-desc">传承至今</text>
    </view>
    <view class="info-divider"></view>
    <view class="info-item">
      <text class="info-label">100%</text>
      <text class="info-desc">有机认证</text>
    </view>
    <view class="info-divider"></view>
    <view class="info-item">
      <text class="info-label">全球</text>
      <text class="info-desc">冷链配送</text>
    </view>
  </view>

  <!-- Bottom Spacing for Tab Bar -->
  <view class="bottom-spacer"></view>
</view>