/* pages/address/address.wxss */

.address-page {
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.address-list {
  padding: 16rpx;
}

.address-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: relative;
  overflow: hidden;
}

.address-card.selectable {
  border: 2rpx solid transparent;
}

.address-card.selectable:active {
  background: #FAFAFA;
}

.default-badge {
  position: absolute;
  top: 0;
  right: 24rpx;
  background: #8B6914;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 0 8rpx 8rpx;
}

.address-info {
  margin-bottom: 16rpx;
}

.address-top {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 26rpx;
  color: #666666;
}

.address-detail {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.address-actions {
  display: flex;
  gap: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.action-btn {
  font-size: 24rpx;
  color: #8B6914;
  padding: 4rpx 0;
}

.delete-btn {
  color: #E54D42;
}

/* Empty State */
.empty-address {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 300rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  background: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon-text {
  font-size: 80rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999999;
}

/* Bottom Add Bar */
.add-address-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.add-btn {
  background: #8B6914;
  color: #ffffff;
  text-align: center;
  padding: 30rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.add-btn::after {
  border: none;
}
