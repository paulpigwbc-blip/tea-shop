/* pages/address/address.wxss */

.address-page {
  background: #FFFFFF;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.address-list {
  padding: 16rpx;
}

.address-card {
  background: #FFFFFF;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #EEEEEE;
  position: relative;
  overflow: hidden;
}

.address-card.selectable {
  border: 2rpx solid transparent;
}

.address-card.selectable:active {
  background: #FAFAFA;
}

.default-badge {
  position: absolute;
  top: 0;
  right: 24rpx;
  background: #7BAF8A;
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 0 8rpx 8rpx;
}

.address-info {
  margin-bottom: 16rpx;
}

.address-top {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.address-name {
  font-size: 34rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 30rpx;
  color: #666666;
}

.address-detail {
  font-size: 30rpx;
  color: #666666;
  line-height: 1.6;
}

.address-actions {
  display: flex;
  gap: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEEEEE;
}

.action-btn {
  font-size: 24rpx;
  color: #7BAF8A;
  padding: 4rpx 0;
}

.delete-btn {
  color: #888888;
}

/* Empty State */
.empty-address {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 300rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  background: #F8F8F8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon-shape {
  width: 40rpx;
  height: 40rpx;
  border: 6rpx solid #7BAF8A;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
}

.empty-text {
  font-size: 34rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: #888888;
}

/* Bottom Add Bar */
.add-address-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #EEEEEE;
}

.add-btn {
  background: #7BAF8A;
  color: #FFFFFF;
  text-align: center;
  padding: 30rpx;
  border-radius: 4rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.add-btn::after {
  border: none;
}
