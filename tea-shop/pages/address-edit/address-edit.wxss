/* pages/address-edit/address-edit.wxss */

.edit-page {
  background: #FFFFFF;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* Form Card */
.form-card {
  background: #FFFFFF;
  margin: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.form-item:last-child {
  border-bottom: none;
}

.detail-item {
  align-items: flex-start;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333333;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  text-align: right;
}

.form-picker {
  flex: 1;
}

.picker-display {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  font-size: 28rpx;
  color: #333333;
}

.picker-display.placeholder {
  color: #888888;
}

.picker-arrow {
  font-size: 32rpx;
  color: #C0C0C0;
  margin-left: 12rpx;
}

.form-textarea {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  min-height: 120rpx;
  line-height: 1.6;
}

/* Default Switch Row */
.default-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  margin: 16rpx;
  border-radius: 8rpx;
  padding: 28rpx 30rpx;
}

.default-label {
  font-size: 28rpx;
  color: #333333;
}

.toggle-switch {
  width: 88rpx;
  height: 48rpx;
  border-radius: 24rpx;
  position: relative;
  transition: background 0.3s;
}

.toggle-switch.on {
  background: #7BAF8A;
}

.toggle-switch.off {
  background: #E0E0E0;
}

.toggle-knob {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #FFFFFF;
  position: absolute;
  top: 4rpx;
  transition: left 0.3s;
  border: 1rpx solid #EEEEEE;
}

.toggle-switch.on .toggle-knob {
  left: 44rpx;
}

.toggle-switch.off .toggle-knob {
  left: 4rpx;
}

/* Save Bar */
.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #EEEEEE;
}

.save-btn {
  background: #7BAF8A;
  color: #FFFFFF;
  text-align: center;
  padding: 24rpx;
  border-radius: 4rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.save-btn::after {
  border: none;
}
