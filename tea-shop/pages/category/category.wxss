/* pages/category/category.wxss - 喜茶清爽极简 */

.category-page {
  height: calc(100vh - 110rpx - env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

/* Top Bar */
.top-bar {
  display: flex;
  align-items: center;
  padding: 30rpx 40rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #EEEEEE;
  flex-shrink: 0;
}

.search-bar {
  flex: 1;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #F8F8F8;
  border-radius: 4rpx;
  padding: 18rpx 24rpx;
}

.search-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  color: #888888;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  height: 40rpx;
  line-height: 40rpx;
  font-weight: 400;
}

.search-placeholder {
  color: #888888;
  font-size: 28rpx;
  font-weight: 400;
}

.search-clear {
  font-size: 24rpx;
  color: #888888;
  padding: 8rpx;
  flex-shrink: 0;
}

/* Content Area */
.content-area {
  display: flex;
  flex: 1;
  overflow: hidden;
  background: #FFFFFF;
}

/* Left Category Sidebar */
.category-sidebar {
  width: 160rpx;
  height: 100%;
  background: #FFFFFF;
  flex-shrink: 0;
  border-right: 1rpx solid #EEEEEE;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 48rpx 16rpx;
  background: #FFFFFF;
  transition: background 0.3s ease;
}

.category-item.active {
  background: #F0F0F0;
}

.category-name {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  letter-spacing: 2rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.category-item.active .category-name {
  color: #333333;
  letter-spacing: 2rpx;
  font-weight: 600;
}

/* 选中指示线 */
.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 3rpx;
  background: #333333;
  border-radius: 2rpx;
}

/* Right Product Area */
.product-area {
  flex: 1;
  height: 100%;
  padding: 40rpx 40rpx 40rpx 20rpx;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

/* 产品卡 - 纯白底极细边框 */
.product-card {
  width: 48%;
  background: #F8F8F8;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  transition: transform 0.2s ease;
}

.product-card:active {
  transform: scale(0.98);
}

.product-img-wrap {
  width: 100%;
  height: 280rpx;
  position: relative;
  background: #F8F8F8;
}

.product-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F8F8F8;
}

.product-placeholder-text {
  font-size: 56rpx;
  color: #E0E0E0;
  font-weight: 300;
}

.product-img-real {
  width: 100%;
  height: 100%;
  display: block;
}

.product-info {
  padding: 24rpx;
  background: #FFFFFF;
}

.product-name {
  display: block;
  font-size: 28rpx;
  font-weight: 400;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
  letter-spacing: 1rpx;
}

.product-name:active {
  color: #7BAF8A;
}

.product-desc {
  display: block;
  font-size: 24rpx;
  color: #888888;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 20rpx;
  font-weight: 400;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-price-row {
  display: flex;
  align-items: baseline;
}

.product-price-symbol {
  font-size: 20rpx;
  color: #444444;
  font-weight: bold;
}

.product-price {
  font-size: 30rpx;
  color: #444444;
  font-weight: bold;
}

/* Quantity Control - 纤细 */
.product-qty-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 300;
  transition: background 0.2s ease;
}

.qty-btn.hidden {
  visibility: hidden;
}

.minus-btn {
  background: #F2F2F2;
  color: #888888;
}

.plus-btn {
  background: #EEEEEE;
  color: #333333;
}

.qty-btn:active {
  background: #E0E0E0;
}

.qty-num {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  min-width: 40rpx;
  text-align: center;
}

/* Empty State */
.empty-state {
  padding: 160rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #888888;
  font-weight: 400;
}

/* Bottom Spacer */
.bottom-spacer {
  height: 120rpx;
}

/* Fly-to-cart animation dot */
.fly-dot {
  position: fixed;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #7BAF8A;
  z-index: 9999;
  pointer-events: none;
  opacity: 1;
}
