/* pages/order-confirm/order-confirm.wxss */

.confirm-page {
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 0;
}

/* Address Section */
.address-section {
  background: #ffffff;
  margin-bottom: 16rpx;
}

.address-card {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
}

.address-left {
  margin-right: 20rpx;
}

.address-icon {
  font-size: 36rpx;
}

.address-content {
  flex: 1;
}

.address-top-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.address-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 16rpx;
}

.address-phone {
  font-size: 26rpx;
  color: #666666;
}

.address-detail {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
}

.address-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
  padding: 10rpx;
}

.no-address {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
}

.no-address-text {
  font-size: 28rpx;
  color: #999999;
}

/* Items Section */
.items-section {
  background: #ffffff;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.section-dot {
  width: 8rpx;
  height: 28rpx;
  background: #8B6914;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.order-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.order-item:last-child {
  border-bottom: none;
}

.item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.item-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-img-real {
  width: 100%;
  height: 100%;
}

.item-placeholder-text {
  font-size: 36rpx;
  color: rgba(139, 105, 20, 0.2);
  font-weight: bold;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-right {
  text-align: right;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.item-price {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 6rpx;
}

.item-qty {
  font-size: 28rpx;
  color: #999999;
}

/* Note Section */
.note-section {
  background: #ffffff;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
}

.note-input {
  width: 100%;
  height: 120rpx;
  font-size: 26rpx;
  color: #333333;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-top: 12rpx;
}

/* Price Section */
.price-section {
  background: #ffffff;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.price-label {
  font-size: 26rpx;
  color: #666666;
}

.price-value {
  font-size: 26rpx;
  color: #333333;
}

.total-row {
  border-top: 1rpx solid #EEEEEE;
  padding-top: 16rpx;
  margin-top: 8rpx;
}

.price-total {
  font-size: 36rpx;
  font-weight: bold;
  color: #E54D42;
}

/* Bottom Spacer */
.bottom-spacer {
  height: 140rpx;
}

/* Submit Bar */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.submit-total {
  flex: 1;
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  padding-right: 20rpx;
}

.submit-label {
  font-size: 28rpx;
  color: #333333;
}

.submit-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #E54D42;
}

.submit-btn {
  background: #8B6914;
  color: #ffffff;
  padding: 28rpx 68rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.submit-btn.disabled {
  background: #CCCCCC;
}

.submit-btn::after {
  border: none;
}
