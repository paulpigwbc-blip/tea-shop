/* pages/contact/contact.wxss - 极简高级・紧凑 */

.contact-page {
  background: #FFFFFF;
  min-height: 100vh;
}

/* ========== Hero Section ========== */
.hero-section {
  position: relative;
  width: 100%;
  height: 340rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: relative;
  z-index: 2;
  padding: 70rpx 60rpx 40rpx;
  text-align: center;
}

.hero-tag {
  font-size: 20rpx;
  letter-spacing: 6rpx;
  color: #999999;
  margin-bottom: 20rpx;
  font-weight: 400;
  font-family: Georgia, 'Times New Roman', serif;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 300;
  color: #333333;
  letter-spacing: 10rpx;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.hero-subtitle {
  font-size: 24rpx;
  color: #666666;
  letter-spacing: 3rpx;
  margin-bottom: 30rpx;
  font-weight: 400;
}

/* ========== Section Header ========== */
.section-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 60rpx;
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: 400;
  color: #666666;
  letter-spacing: 6rpx;
  margin: 0 24rpx;
}

/* ========== Contact Section ========== */
.contact-section {
  padding: 0 60rpx;
  margin-bottom: 40rpx;
}

.contact-item {
  display: flex;
  flex-direction: column;
  padding: 20rpx 0;
}

.contact-item:active {
  opacity: 0.6;
}

.contact-item-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.contact-item-title {
  display: flex;
  align-items: center;
}

.contact-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 14rpx;
}

.contact-item-label {
  font-size: 28rpx;
  color: #333333;
  letter-spacing: 2rpx;
  font-weight: 500;
}

.contact-item-arrow {
  font-size: 24rpx;
  color: #C0C0C0;
  font-weight: 300;
}

.contact-item-action {
  font-size: 22rpx;
  color: #7BAF8A;
  letter-spacing: 2rpx;
  font-weight: 400;
}

.contact-item-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.item-divider {
  height: 1rpx;
  background: #F2F2F2;
}

/* ========== QR Code Section ========== */
.qrcode-section {
  padding: 0 60rpx 40rpx;
  text-align: center;
}

.qrcode-wrap {
  display: flex;
  justify-content: center;
}

.qrcode-placeholder {
  width: 300rpx;
  height: 300rpx;
  background: #F8F8F8;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1rpx solid #EEEEEE;
}

.qrcode-text {
  font-size: 28rpx;
  color: #C0C0C0;
  margin-bottom: 6rpx;
  font-weight: 300;
  letter-spacing: 4rpx;
}

.qrcode-subtext {
  font-size: 20rpx;
  color: #AAAAAA;
  letter-spacing: 2rpx;
}

/* ========== Brand Quote ========== */
.brand-quote {
  padding: 30rpx 80rpx;
  text-align: center;
}

.quote-mark {
  font-size: 40rpx;
  color: #E0E0E0;
  font-weight: 300;
  line-height: 1;
  margin-bottom: -12rpx;
  font-family: Georgia, 'Times New Roman', serif;
}

.quote-text {
  display: block;
  font-size: 28rpx;
  color: #999999;
  line-height: 2;
  letter-spacing: 2rpx;
}

/* ========== Bottom Spacer ========== */
.bottom-spacer {
  height: 120rpx;
}
