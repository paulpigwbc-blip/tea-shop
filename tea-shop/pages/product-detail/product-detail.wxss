/* pages/product-detail/product-detail.wxss */

.detail-page {
  background: #FFFFFF;
  min-height: 100vh;
  padding-bottom: 0;
}

/* Image Section */
.detail-img-section {
  width: 100%;
  height: 600rpx;
}

.detail-swiper {
  width: 100%;
  height: 100%;
}

.swiper-img {
  width: 100%;
  height: 600rpx;
}

.detail-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-placeholder-text {
  font-size: 120rpx;
  color: #E0E0E0;
  font-weight: 300;
}

/* Info Section */
.detail-info-section {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 16rpx;
}

.detail-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.detail-price-symbol {
  font-size: 28rpx;
  color: #444444;
  font-weight: bold;
  margin-right: 4rpx;
}

.detail-price {
  font-size: 48rpx;
  color: #444444;
  font-weight: bold;
}

.detail-original-price {
  font-size: 24rpx;
  color: #888888;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.detail-name {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.detail-desc {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.detail-tags {
  display: flex;
  gap: 16rpx;
}

.detail-tag {
  background: #F2F2F2;
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
}

.detail-tag text {
  font-size: 24rpx;
  color: #666666;
}

/* Story Section */
.detail-story {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 16rpx;
}

.story-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
}

.story-dot {
  width: 8rpx;
  height: 28rpx;
  background: #7BAF8A;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.story-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 2;
}

/* Quantity Section */
.detail-qty-section {
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
}

.qty-label {
  font-size: 28rpx;
  color: #333333;
}

.qty-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 4rpx;
  background: #F2F2F2;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333333;
  border: 1rpx solid #EEEEEE;
}

.qty-btn.disabled {
  color: #C0C0C0;
}

.qty-num {
  min-width: 60rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333333;
  font-weight: 500;
}

/* Cart Info */
.cart-info {
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  margin-bottom: 16rpx;
}

.cart-info-text {
  font-size: 26rpx;
  color: #888888;
}

.cart-info-link {
  font-size: 26rpx;
  color: #7BAF8A;
}

/* Bottom Spacer */
.bottom-spacer {
  height: 140rpx;
}

/* Fixed Bottom Bar */
.detail-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: #FFFFFF;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #EEEEEE;
  z-index: 100;
}

.bar-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24rpx;
  position: relative;
}

.bar-cart-icon {
  font-size: 40rpx;
}

.bar-cart-text {
  font-size: 24rpx;
  color: #888888;
  margin-top: 4rpx;
}

.bar-cart-badge {
  position: absolute;
  top: -8rpx;
  right: 6rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #7BAF8A;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.bar-cart-badge text {
  font-size: 20rpx;
  color: #ffffff;
}

.bar-add-cart {
  flex: 1;
  background: #7BAF8A;
  color: #FFFFFF;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 8rpx 0 0 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-left: 20rpx;
}

.bar-buy-now {
  flex: 1;
  background: #5E8A6E;
  color: #FFFFFF;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 0 8rpx 8rpx 0;
  font-size: 32rpx;
  font-weight: 500;
}

.bar-add-cart::after, .bar-buy-now::after {
  border: none;
}
