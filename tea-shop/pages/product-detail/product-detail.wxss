/* pages/product-detail/product-detail.wxss */

.detail-page {
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 0;
}

/* Image Section */
.detail-img-section {
  width: 100%;
  height: 600rpx;
}

.detail-swiper {
  width: 100%;
  height: 100%;
}

.swiper-img {
  width: 100%;
  height: 600rpx;
}

.detail-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-placeholder-text {
  font-size: 120rpx;
  color: rgba(139, 105, 20, 0.15);
  font-weight: bold;
}

/* Info Section */
.detail-info-section {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 16rpx;
}

.detail-price-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.detail-price-symbol {
  font-size: 28rpx;
  color: #E54D42;
  font-weight: bold;
  margin-right: 4rpx;
}

.detail-price {
  font-size: 48rpx;
  color: #E54D42;
  font-weight: bold;
}

.detail-original-price {
  font-size: 24rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 16rpx;
}

.detail-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.detail-desc {
  display: block;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.detail-tags {
  display: flex;
  gap: 16rpx;
}

.detail-tag {
  background: rgba(139, 105, 20, 0.08);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.detail-tag text {
  font-size: 24rpx;
  color: #8B6914;
}

/* Story Section */
.detail-story {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 16rpx;
}

.story-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.story-dot {
  width: 8rpx;
  height: 28rpx;
  background: #8B6914;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.story-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 2;
}

/* Quantity Section */
.detail-qty-section {
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
}

.qty-label {
  font-size: 28rpx;
  color: #333333;
}

.qty-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333333;
  border: 1rpx solid #EEEEEE;
}

.qty-btn.disabled {
  color: #CCCCCC;
}

.qty-num {
  min-width: 60rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
}

/* Cart Info */
.cart-info {
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  margin-bottom: 16rpx;
}

.cart-info-text {
  font-size: 26rpx;
  color: #999999;
}

.cart-info-link {
  font-size: 26rpx;
  color: #8B6914;
}

/* Bottom Spacer */
.bottom-spacer {
  height: 140rpx;
}

/* Fixed Bottom Bar */
.detail-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bar-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24rpx;
  position: relative;
}

.bar-cart-icon {
  font-size: 40rpx;
}

.bar-cart-text {
  font-size: 24rpx;
  color: #666666;
  margin-top: 4rpx;
}

.bar-cart-badge {
  position: absolute;
  top: -8rpx;
  right: 6rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #E54D42;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.bar-cart-badge text {
  font-size: 20rpx;
  color: #ffffff;
}

.bar-add-cart {
  flex: 1;
  background: #5B7744;
  color: #ffffff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 40rpx 0 0 40rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-left: 20rpx;
}

.bar-buy-now {
  flex: 1;
  background: #8B6914;
  color: #ffffff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 0 40rpx 40rpx 0;
  font-size: 32rpx;
  font-weight: bold;
}

.bar-add-cart::after, .bar-buy-now::after {
  border: none;
}
