<!-- pages/order-detail/order-detail.wxml -->
<view class="detail-page" wx:if="{{order}}">

  <!-- Status Banner -->
  <view class="status-banner" style="background: linear-gradient(135deg, {{statusColor}}, {{statusColor}}dd);">
    <text class="status-text">{{statusText}}</text>
    <text class="status-desc" wx:if="{{order.status === 'pending'}}">订单待付款，请尽快完成支付</text>
    <text class="status-desc" wx:if="{{order.status === 'cancel_pending'}}">取消申请中，等待商家处理</text>
    <text class="status-desc" wx:if="{{order.status === 'paid'}}">已支付，等待商家发货。发货前可申请退款</text>
    <text class="status-desc" wx:if="{{order.status === 'refund_pending'}}">退款申请中，等待商家处理</text>
    <text class="status-desc" wx:if="{{order.status === 'shipped'}}">商家已发货，请注意查收</text>
    <text class="status-desc" wx:if="{{order.status === 'completed'}}">感谢您的购买</text>
    <text class="status-desc" wx:if="{{order.status === 'cancelled'}}">订单已取消</text>
    <view class="refund-info" wx:if="{{order.status === 'cancelled' && order.refund}}">
      <text class="refund-label">退款状态：</text>
      <text class="refund-status refund-{{order.refund.status}}">
        {{order.refund.status === 'success' ? '已退款 ¥' + order.refund.amount : (order.refund.status === 'processing' ? '退款中' : '退款失败')}}
      </text>
    </view>
    <!-- Refund rejection info -->
    <view class="refund-info" wx:if="{{order.status === 'paid' && order.refundRejectedAt}}">
      <text class="refund-label">退款已被商家拒绝</text>
    </view>
  </view>

  <!-- Order Info Card -->
  <view class="info-card">
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <text class="info-value">{{order.orderNo}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">下单时间</text>
      <text class="info-value">{{formattedDate}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">配送方式</text>
      <text class="info-value">快递配送</text>
    </view>
    <view class="info-row" wx:if="{{order.note}}">
      <text class="info-label">订单备注</text>
      <text class="info-value">{{order.note}}</text>
    </view>
    <view class="info-row" wx:if="{{order.payment}}">
      <text class="info-label">支付方式</text>
      <text class="info-value">{{order.payment.method === 'mock' ? '模拟支付' : '微信支付'}}</text>
    </view>
    <view class="info-row" wx:if="{{order.payment}}">
      <text class="info-label">支付时间</text>
      <text class="info-value">{{formatDate(order.payment.paidAt)}}</text>
    </view>
  </view>

  <!-- Refund Info Card -->
  <view class="info-card refund-card" wx:if="{{order.refund}}">
    <view class="card-title">
      <view class="card-title-icon-wrap">
        <view class="card-title-icon icon-refund"></view>
      </view>
      <text>退款信息</text>
    </view>
    <view class="info-row">
      <text class="info-label">退款金额</text>
      <text class="info-value">¥{{order.refund.amount}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">退款时间</text>
      <text class="info-value">{{formatDate(order.refund.refundAt)}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">退款状态</text>
      <text class="info-value refund-{{order.refund.status}}">
        {{order.refund.status === 'success' ? '退款成功' : (order.refund.status === 'processing' ? '退款中' : '退款失败')}}
      </text>
    </view>
    <view class="info-row" wx:if="{{order.refund.reason}}">
      <text class="info-label">退款原因</text>
      <text class="info-value">{{order.refund.reason}}</text>
    </view>
    <view class="info-row" wx:if="{{order.refund.refundId}}">
      <text class="info-label">退款单号</text>
      <text class="info-value">{{order.refund.refundId}}</text>
    </view>
  </view>

  <!-- Delivery Address -->
  <view class="address-card" wx:if="{{order.type === 'delivery' && order.address}}">
    <view class="card-title">
      <view class="card-title-icon-wrap">
        <view class="card-title-icon icon-location"></view>
      </view>
      <text>收货地址</text>
    </view>
    <text class="addr-name">{{order.address.name}} {{order.address.phone}}</text>
    <text class="addr-detail">{{order.address.province}}{{order.address.city}}{{order.address.district}}{{order.address.detail}}</text>
  </view>

  <!-- Express Info Card -->
  <view class="express-card" wx:if="{{order.express}}">
    <view class="card-title">
      <view class="card-title-icon-wrap">
        <view class="card-title-icon icon-express"></view>
      </view>
      <text>快递信息</text>
    </view>
    <view class="express-info-row">
      <text class="info-label">快递公司</text>
      <text class="info-value">{{order.express.company}}</text>
    </view>
    <view class="express-info-row">
      <text class="info-label">快递单号</text>
      <view class="express-tracking">
        <text class="info-value tracking-no">{{order.express.trackingNo}}</text>
        <view class="copy-tracking-btn" catchtap="copyTrackingNo">
          <text>复制</text>
        </view>
      </view>
    </view>
    <view class="express-info-row" wx:if="{{order.express.shippedAt}}">
      <text class="info-label">发货时间</text>
      <text class="info-value">{{formatDate(order.express.shippedAt)}}</text>
    </view>
  </view>

  <!-- Order Items -->
  <view class="items-card">
    <view class="card-title">
      <view class="card-title-icon-wrap">
        <view class="card-title-icon icon-bag"></view>
      </view>
      <text>商品详情</text>
    </view>
    <view class="item-row" wx:for="{{order.items}}" wx:key="productId" bindtap="goToProductDetail" data-id="{{item.productId}}">
      <view class="item-img">
        <image class="item-img-real" wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" />
        <view class="item-placeholder" wx:else>
          <text class="placeholder-text">{{item.name[0]}}</text>
        </view>
      </view>
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-qty">x{{item.quantity}}</text>
      </view>
      <text class="item-price">¥{{item.price * item.quantity}}</text>
    </view>
    <view class="total-row">
      <text class="total-label">实付金额</text>
      <text class="total-price">¥{{order.totalPrice}}</text>
    </view>
  </view>

  <!-- Order Timeline -->
  <view class="timeline-card" wx:if="{{timeline.length > 0}}">
    <view class="card-title">
      <view class="card-title-icon-wrap">
        <view class="card-title-icon icon-timeline"></view>
      </view>
      <text>订单轨迹</text>
    </view>
    <view class="timeline-list">
      <view class="timeline-item {{index === 0 ? 'timeline-latest' : ''}}"
            wx:for="{{timeline}}" wx:key="time">
        <view class="timeline-dot"></view>
        <view class="timeline-content">
          <text class="timeline-label">{{item.label}}</text>
          <text class="timeline-time">{{item.time}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Action Buttons -->
  <view class="action-section">
    <view class="action-btn pay-action" wx:if="{{order.status === 'pending'}}" bindtap="payOrder">
      <text>立即付款</text>
    </view>
    <view class="action-btn cancel-action" wx:if="{{order.status === 'pending'}}" bindtap="cancelOrder">
      <text>取消订单</text>
    </view>
    <view class="action-btn cancel-pending-hint" wx:if="{{order.status === 'cancel_pending'}}">
      <text>取消处理中</text>
    </view>
    <view class="action-btn urgency-action" wx:if="{{order.status === 'paid'}}" bindtap="requestUrgency">
      <text>催促发货</text>
    </view>
    <view class="action-btn refund-action" wx:if="{{order.status === 'paid'}}" bindtap="requestRefund">
      <text>申请退款</text>
    </view>
    <view class="action-btn refund-pending-hint" wx:if="{{order.status === 'refund_pending'}}">
      <text>退款处理中</text>
    </view>
    <view class="action-btn confirm-action" wx:if="{{order.status === 'shipped'}}" bindtap="confirmReceipt">
      <text>确认收货</text>
    </view>
    <view class="action-btn reorder-action" wx:if="{{order.status === 'completed' || order.status === 'cancelled'}}" bindtap="reorder">
      <text>再来一单</text>
    </view>
    <view class="action-btn list-action" bindtap="goToOrderList">
      <text>查看全部订单</text>
    </view>
  </view>

  <!-- Mock Payment Popup -->
  <view class="payment-mask" wx:if="{{showPayPopup}}" bindtap="closePayPopup">
    <view class="payment-popup" catchtap>
      <!-- Popup Header -->
      <view class="pay-popup-header">
        <text class="pay-popup-title">确认支付</text>
        <view class="pay-popup-close" bindtap="closePayPopup">
          <text>&times;</text>
        </view>
      </view>
      <!-- Amount -->
      <view class="pay-amount-section">
        <text class="pay-amount-label">支付金额</text>
        <view class="pay-amount-value">
          <text class="pay-amount-symbol">¥</text>
          <text class="pay-amount-num">{{order.totalPrice}}</text>
        </view>
      </view>
      <!-- Payment Method -->
      <view class="pay-method-section">
        <text class="pay-method-label">支付方式</text>
        <view class="pay-method-item pay-method-selected">
          <view class="pay-method-icon wechat-icon">
            <text class="wechat-pay-text">W</text>
          </view>
          <view class="pay-method-info">
            <text class="pay-method-name">微信支付</text>
            <text class="pay-method-desc">模拟支付 (测试)</text>
          </view>
          <view class="pay-method-check">
            <text>&#10003;</text>
          </view>
        </view>
      </view>
      <!-- Pay Button -->
      <view class="pay-popup-btn {{payProcessing ? 'disabled' : ''}}" bindtap="confirmMockPay">
        <text wx:if="{{!payProcessing && !paySuccess}}">确认支付</text>
        <text wx:if="{{payProcessing}}">支付处理中...</text>
        <text wx:if="{{paySuccess}}">支付成功</text>
      </view>
    </view>
  </view>
</view>
