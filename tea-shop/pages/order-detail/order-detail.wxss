/* pages/order-detail/order-detail.wxss */

.detail-page {
  background: #FFFFFF;
  min-height: 100vh;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* Status Banner */
.status-banner {
  padding: 50rpx 30rpx;
  color: #ffffff;
}

.status-text {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.status-desc {
  display: block;
  font-size: 26rpx;
  color: #DDDDDD;
}

/* Refund Info */
.refund-info {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  font-size: 26rpx;
}

.refund-label {
  margin-right: 8rpx;
  color: #EEEEEE;
}

.refund-status {
  font-weight: bold;
}

.refund-success {
  color: #4CAF50;
}

.refund-processing {
  color: #FF9800;
}

.refund-failed {
  color: #F44336;
}

/* Info Card */
.info-card {
  background: #ffffff;
  border-radius: 8rpx;
  margin: -20rpx 16rpx 16rpx;
  padding: 24rpx;
  position: relative;
  z-index: 10;
  border: 1rpx solid #EEEEEE;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 30rpx;
  color: #888888;
}

.info-value {
  font-size: 30rpx;
  color: #333333;
}

/* Address Card */
.address-card {
  background: #ffffff;
  border-radius: 8rpx;
  margin: 0 16rpx 16rpx;
  padding: 24rpx;
}

.card-title {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 34rpx;
  font-weight: 500;
  color: #333333;
}

.card-title-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #7BAF8A;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

/* CSS-drawn icons - minimalist white shapes */
.card-title-icon {
  position: relative;
}

/* Refund/coin icon */
.icon-refund {
  width: 18rpx;
  height: 18rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 50%;
}
.icon-refund::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 6rpx;
  height: 2rpx;
  background: #FFFFFF;
  transform: translate(-50%, -50%);
  box-shadow: 0 -4rpx 0 #FFFFFF, 0 4rpx 0 #FFFFFF;
}

/* Location pin icon */
.icon-location {
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
}

/* Shopping bag icon */
.icon-bag {
  width: 18rpx;
  height: 18rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 0 0 4rpx 4rpx;
}
.icon-bag::before {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 12rpx;
  height: 8rpx;
  border: 3rpx solid #FFFFFF;
  border-bottom: none;
  border-radius: 50% 50% 0 0;
}

/* Timeline/clock icon */
.icon-timeline {
  width: 16rpx;
  height: 16rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 50%;
}

/* Express/delivery truck icon */
.icon-express {
  width: 22rpx;
  height: 14rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 3rpx;
}
.icon-express::before {
  content: '';
  position: absolute;
  top: 50%;
  left: -5rpx;
  width: 4rpx;
  height: 4rpx;
  border: 2rpx solid #FFFFFF;
  border-radius: 50%;
  transform: translateY(-50%);
}
.icon-express::after {
  content: '';
  position: absolute;
  top: 50%;
  right: -5rpx;
  width: 4rpx;
  height: 4rpx;
  border: 2rpx solid #FFFFFF;
  border-radius: 50%;
  transform: translateY(-50%);
}

.addr-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.addr-detail {
  font-size: 30rpx;
  color: #666666;
  line-height: 1.5;
}

/* Items Card */
.items-card {
  background: #ffffff;
  border-radius: 8rpx;
  margin: 0 16rpx 16rpx;
  padding: 24rpx;
}

.item-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.item-row:last-of-type {
  border-bottom: none;
}

.item-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.item-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-img-real {
  width: 100%;
  height: 100%;
}

.placeholder-text {
  font-size: 32rpx;
  color: #E0E0E0;
  font-weight: 300;
}

.item-info {
  flex: 1;
}

.item-name {
  display: block;
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.item-qty {
  font-size: 30rpx;
  color: #888888;
}

.item-price {
  font-size: 30rpx;
  font-weight: 500;
  color: #444444;
  flex-shrink: 0;
}

.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  margin-top: 12rpx;
  border-top: 1rpx solid #EEEEEE;
}

.total-label {
  font-size: 30rpx;
  color: #333333;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #444444;
}

/* Action Section */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #EEEEEE;
  z-index: 100;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 4rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.pay-action {
  background: #7BAF8A;
  color: #FFFFFF;
}

.cancel-action {
  background: #F2F2F2;
  color: #888888;
}

.cancel-pending-hint {
  background: #FFF3E0;
  color: #FF9800;
  opacity: 0.85;
  pointer-events: none;
}

.urgency-action {
  background: #7BAF8A;
  color: #FFFFFF;
}

.refund-action {
  background: #FFFFFF;
  color: #E54D42;
  border: 2rpx solid #E54D42;
}

.refund-pending-hint {
  background: #FFF3E0;
  color: #FF9800;
  opacity: 0.85;
  pointer-events: none;
}

.confirm-action {
  background: #7BAF8A;
  color: #FFFFFF;
}

.reorder-action {
  background: #7BAF8A;
  color: #FFFFFF;
}

.list-action {
  background: #FFFFFF;
  color: #7BAF8A;
  border: 2rpx solid #7BAF8A;
}

.action-btn::after {
  border: none;
}

/* ===== Mock Payment Popup ===== */
.payment-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.payment-popup {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.pay-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.pay-popup-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.pay-popup-close {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #888888;
}

/* Amount */
.pay-amount-section {
  text-align: center;
  padding: 30rpx 0 40rpx;
}

.pay-amount-label {
  font-size: 26rpx;
  color: #888888;
  display: block;
  margin-bottom: 16rpx;
}

.pay-amount-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.pay-amount-symbol {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 4rpx;
}

.pay-amount-num {
  font-size: 64rpx;
  font-weight: bold;
  color: #333333;
}

/* Payment Method */
.pay-method-section {
  margin-bottom: 40rpx;
}

.pay-method-label {
  font-size: 26rpx;
  color: #888888;
  display: block;
  margin-bottom: 20rpx;
}

.pay-method-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 8rpx;
  border: 2rpx solid transparent;
}

.pay-method-selected {
  border-color: #7BAF8A;
  background: #F0F5F2;
}

.pay-method-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.wechat-icon {
  background: #07C160;
}

.wechat-pay-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
}

.pay-method-info {
  flex: 1;
}

.pay-method-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.pay-method-desc {
  font-size: 22rpx;
  color: #07C160;
}

.pay-method-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
}

/* Pay Button */
.pay-popup-btn {
  width: 100%;
  padding: 26rpx 0;
  border-radius: 44rpx;
  background: #07C160;
  color: #ffffff;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 10rpx;
}

.pay-popup-btn.disabled {
  background: #E0E0E0;
  pointer-events: none;
}

/* Refund Card Styles */
.refund-card {
  border: 2rpx solid #4CAF50;
  background: #F9FBE7;
}

.refund-card .refund-success {
  color: #2E7D32;
  font-weight: bold;
}

.refund-card .refund-processing {
  color: #E65100;
  font-weight: bold;
}

.refund-card .refund-failed {
  color: #C62828;
  font-weight: bold;
}

/* Express Card */
.express-card {
  background: #ffffff;
  border-radius: 8rpx;
  margin: 0 16rpx 16rpx;
  padding: 24rpx;
}

.express-card .card-title {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 34rpx;
  font-weight: 500;
  color: #333333;
}

.express-card .card-title-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #7BAF8A;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.express-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.express-info-row:last-child {
  border-bottom: none;
}

.express-info-row .info-label {
  font-size: 30rpx;
  color: #888888;
}

.express-info-row .info-value {
  font-size: 30rpx;
  color: #333333;
}

.express-tracking {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.tracking-no {
  font-family: 'Courier New', monospace;
}

.copy-tracking-btn {
  padding: 8rpx 20rpx;
  border: 2rpx solid #7BAF8A;
  border-radius: 4rpx;
  font-size: 24rpx;
  color: #7BAF8A;
}

/* ===== Timeline Card ===== */
.timeline-card {
  background: #ffffff;
  border-radius: 8rpx;
  margin: 0 16rpx 16rpx;
  padding: 24rpx;
}

.timeline-list {
  padding-left: 4rpx;
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  position: relative;
}

.timeline-item::after {
  content: '';
  position: absolute;
  left: 11rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: #EEEEEE;
}

.timeline-item:last-child::after {
  display: none;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #DDDDDD;
  border: 4rpx solid #FFFFFF;
  flex-shrink: 0;
  margin-right: 20rpx;
  margin-top: 4rpx;
  position: relative;
  z-index: 1;
  box-sizing: border-box;
}

.timeline-latest .timeline-dot {
  background: #7BAF8A;
}

.timeline-content {
  flex: 1;
}

.timeline-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.timeline-latest .timeline-label {
  color: #7BAF8A;
  font-weight: bold;
}

.timeline-time {
  font-size: 24rpx;
  color: #999999;
}
