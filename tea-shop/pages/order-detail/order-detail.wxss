/* pages/order-detail/order-detail.wxss */

.detail-page {
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* Status Banner */
.status-banner {
  padding: 50rpx 30rpx;
  color: #ffffff;
}

.status-text {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.status-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* Info Card */
.info-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: -20rpx 16rpx 16rpx;
  padding: 24rpx;
  position: relative;
  z-index: 10;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999999;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
}

/* Address Card */
.address-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 16rpx 16rpx;
  padding: 24rpx;
}

.card-title {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.card-title-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.addr-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.addr-detail {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

/* Items Card */
.items-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin: 0 16rpx 16rpx;
  padding: 24rpx;
}

.item-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.item-row:last-of-type {
  border-bottom: none;
}

.item-img {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.item-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-img-real {
  width: 100%;
  height: 100%;
}

.placeholder-text {
  font-size: 32rpx;
  color: rgba(139, 105, 20, 0.2);
  font-weight: bold;
}

.item-info {
  flex: 1;
}

.item-name {
  display: block;
  font-size: 34rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.item-qty {
  font-size: 28rpx;
  color: #999999;
}

.item-price {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
  flex-shrink: 0;
}

.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  margin-top: 12rpx;
  border-top: 2rpx solid #EEEEEE;
}

.total-label {
  font-size: 28rpx;
  color: #333333;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #E54D42;
}

/* Action Section */
.action-section {
  padding: 0 16rpx;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.pay-action {
  background: #E54D42;
  color: #ffffff;
}

.cancel-action {
  background: #F5F5F5;
  color: #999999;
}

.confirm-action {
  background: #5B7744;
  color: #ffffff;
}

.reorder-action {
  background: #8B6914;
  color: #ffffff;
}

.list-action {
  background: #ffffff;
  color: #8B6914;
  border: 2rpx solid #8B6914;
}

.action-btn::after {
  border: none;
}

/* ===== Mock Payment Popup ===== */
.payment-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.payment-popup {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.pay-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.pay-popup-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.pay-popup-close {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999999;
}

/* Amount */
.pay-amount-section {
  text-align: center;
  padding: 30rpx 0 40rpx;
}

.pay-amount-label {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-bottom: 16rpx;
}

.pay-amount-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.pay-amount-symbol {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 4rpx;
}

.pay-amount-num {
  font-size: 64rpx;
  font-weight: bold;
  color: #333333;
}

/* Payment Method */
.pay-method-section {
  margin-bottom: 40rpx;
}

.pay-method-label {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-bottom: 20rpx;
}

.pay-method-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.pay-method-selected {
  border-color: #07C160;
  background: rgba(7, 193, 96, 0.05);
}

.pay-method-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.wechat-icon {
  background: #07C160;
}

.wechat-pay-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
}

.pay-method-info {
  flex: 1;
}

.pay-method-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.pay-method-desc {
  font-size: 22rpx;
  color: #07C160;
}

.pay-method-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
}

/* Pay Button */
.pay-popup-btn {
  width: 100%;
  padding: 26rpx 0;
  border-radius: 44rpx;
  background: #07C160;
  color: #ffffff;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 10rpx;
}

.pay-popup-btn.disabled {
  background: #CCCCCC;
  pointer-events: none;
}
