<!-- pages/member/member.wxml -->
<view class="member-page">

  <!-- Hero Section: full-bleed image -->
  <view class="hero-section">
    <image class="hero-bg" src="/images/tea-profile.png" mode="aspectFill"></image>
  </view>

  <!-- Menu Section -->
  <view class="menu-section">
    <view class="menu-list">

      <!-- Profile Item (special: shows avatar when logged in) -->
      <view class="menu-item" bindtap="onProfileTap">
        <view class="menu-item-left">
          <block wx:if="{{isLogin && userInfo.avatarUrl}}">
            <image class="menu-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
          </block>
          <block wx:else>
            <image class="menu-icon" src="{{profileIconPath}}" mode="aspectFit"></image>
          </block>
          <text class="menu-name">{{isLogin ? userInfo.nickName : '个人资料'}}</text>
          <text wx:if="{{!isLogin}}" class="menu-hint">点击登录</text>
        </view>
        <text class="menu-arrow">→</text>
      </view>

      <!-- Regular Menu Items -->
      <view class="menu-item" wx:for="{{menuList}}" wx:key="key"
            bindtap="onMenuTap" data-key="{{item.key}}">
        <view class="menu-item-left">
          <image class="menu-icon" src="{{item.iconPath}}" mode="aspectFit"></image>
          <text class="menu-name">{{item.name}}</text>
        </view>
        <text class="menu-arrow">→</text>
      </view>

    </view>
  </view>

  <!-- Brand Quote -->
  <view class="brand-quote">
    <view class="quote-mark">"</view>
    <text class="quote-text">好茶如友，历久弥新。</text>
  </view>

  <!-- Bottom Spacer -->
  <view class="bottom-spacer"></view>
</view>

<!-- Official WeChat Privacy Authorization Popup -->
<view class="privacy-mask" wx:if="{{showPrivacy}}" catchtap="handleDisagreePrivacy">
  <view class="privacy-popup" catchtap>
    <view class="privacy-popup-title">隐私保护提示</view>
    <view class="privacy-popup-body">
      <text class="privacy-popup-text">
        在使用茶语轩小程序前，请仔细阅读{{privacyContractName}}。如您同意，请点击"同意"开始使用。
      </text>
    </view>
    <view class="privacy-popup-contract" bindtap="handleOpenPrivacyContract">
      <text class="privacy-contract-link">{{privacyContractName}}</text>
    </view>
    <view class="privacy-popup-btns">
      <view class="privacy-btn-disagree" bindtap="handleDisagreePrivacy">拒绝</view>
      <button class="privacy-btn-agree"
              id="agree-btn"
              open-type="agreePrivacyAuthorization"
              bindagreeprivacyauthorization="handleAgreePrivacyAuthorization">同意</button>
    </view>
  </view>
</view>
