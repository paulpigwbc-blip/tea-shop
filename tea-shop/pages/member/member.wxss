/* pages/member/member.wxss - 极简高级・紧凑 */

.member-page {
  background: #FFFFFF;
  min-height: 100vh;
}

/* ========== Hero Section ========== */
.hero-section {
  position: relative;
  width: 100%;
  height: 420rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: relative;
  z-index: 2;
  padding: 320rpx 30rpx 50rpx 60rpx;
  text-align: left;
}

.hero-tag {
  font-size: 22rpx;
  letter-spacing: 6rpx;
  color: #999999;
  margin-bottom: 30rpx;
  font-weight: 400;
  font-family: Georgia, 'Times New Roman', serif;
}

.profile-row {
  display: flex;
  align-items: center;
}

.avatar-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 2rpx solid #7BAF8A;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-circle:active {
  background: #F2F2F2;
}

.avatar-letter {
  font-size: 36rpx;
  color: #7BAF8A;
  font-weight: 500;
}

.nickname {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  letter-spacing: 2rpx;
}

.login-link {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  letter-spacing: 2rpx;
}

.welcome-text {
  font-size: 25rpx;
  color: #666666;
  letter-spacing: 2rpx;
  margin-top: 24rpx;
  margin-left: 20rpx;
}

/* ========== Menu Section ========== */
.menu-section {
  padding: 0 60rpx;
  margin-bottom: 50rpx;
}

.menu-list {
  background: #FFFFFF;
  border-radius: 8rpx;
  overflow: hidden;
  border: 1rpx solid #EEEEEE;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 36rpx;
  border-bottom: 1rpx solid #F2F2F2;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #F8F8F8;
}

.menu-item-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 34rpx;
  height: 34rpx;
  margin-right: 24rpx;
}

.menu-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #7BAF8A;
}

.menu-hint {
  font-size: 24rpx;
  color: #AAAAAA;
  margin-left: 12rpx;
  letter-spacing: 1rpx;
}

.menu-name {
  font-size: 30rpx;
  color: #333333;
  letter-spacing: 2rpx;
  font-weight: 500;
}

.menu-arrow {
  font-size: 26rpx;
  color: #C0C0C0;
  font-weight: 300;
}

/* ========== Brand Quote ========== */
.brand-quote {
  padding: 50rpx 80rpx;
  text-align: center;
}

.quote-mark {
  font-size: 48rpx;
  color: #E0E0E0;
  font-weight: 300;
  line-height: 1;
  margin-bottom: -16rpx;
  font-family: Georgia, 'Times New Roman', serif;
}

.quote-text {
  display: block;
  font-size: 26rpx;
  color: #999999;
  line-height: 2;
  letter-spacing: 2rpx;
}

/* ========== Bottom Spacer ========== */
.bottom-spacer {
  height: 160rpx;
}

/* ========== Privacy Authorization Popup ========== */
.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.privacy-popup {
  width: 580rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 48rpx 40rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.privacy-popup-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 28rpx;
  letter-spacing: 2rpx;
}

.privacy-popup-body {
  margin-bottom: 20rpx;
}

.privacy-popup-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
  letter-spacing: 1rpx;
}

.privacy-popup-contract {
  margin-bottom: 36rpx;
}

.privacy-contract-link {
  font-size: 28rpx;
  color: #7BAF8A;
  text-decoration: underline;
}

.privacy-popup-btns {
  display: flex;
  width: 100%;
  gap: 24rpx;
}

.privacy-btn-disagree {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 30rpx;
  color: #888888;
  background: #F2F2F2;
  border-radius: 40rpx;
}

.privacy-btn-agree {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  color: #FFFFFF;
  background: #7BAF8A;
  border-radius: 40rpx;
  border: none;
  padding: 0;
  margin: 0;
}

.privacy-btn-agree::after {
  border: none;
}
