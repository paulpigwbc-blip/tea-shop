/* pages/cart/cart.wxss - 喜茶清爽极简 */

.cart-page {
  min-height: 100vh;
  background: #FFFFFF;
}

.cart-content {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.cart-list {
  flex: 1;
  padding: 40rpx 50rpx;
  padding-top: 100rpx;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

/* Top Checked Summary Bar - 固定在顶部 */
.cart-summary-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 28rpx 50rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #EEEEEE;
  z-index: 99;
}

.summary-check-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #7BAF8A;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.summary-text {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.summary-count {
  font-size: 28rpx;
  color: #888888;
  font-weight: 400;
  flex: 1;
}

.manage-btn {
  font-size: 28rpx;
  color: #7BAF8A;
  font-weight: 500;
  padding: 4rpx 8rpx;
}

/* Cart Item - 线性列表 */
.cart-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 0;
  padding: 28rpx 0;
  margin-bottom: 0;
  border-bottom: 1rpx solid #EEEEEE;
  transition: background 0.2s ease;
}

/* Checkbox */
.cart-checkbox {
  padding: 12rpx;
  flex-shrink: 0;
}

.checkbox-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 1rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #FFFFFF;
  transition: all 0.3s ease;
}

.checkbox-icon.checked {
  background: #7BAF8A;
  border-color: #7BAF8A;
}

/* Cart Item Image */
.cart-item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 6rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin: 0 24rpx;
  background: #F8F8F8;
}

.cart-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F8F8F8;
}

.cart-img-real {
  width: 100%;
  height: 100%;
  display: block;
}

.cart-placeholder-text {
  font-size: 44rpx;
  color: #E0E0E0;
  font-weight: 300;
}

/* Cart Item Info */
.cart-item-info {
  flex: 1;
  min-width: 0;
}

.cart-item-name {
  display: block;
  font-size: 28rpx;
  font-weight: 400;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.cart-item-spec {
  display: block;
  font-size: 24rpx;
  color: #C0C0C0;
  margin-bottom: 18rpx;
  font-weight: 300;
}

.cart-item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cart-item-price {
  font-size: 30rpx;
  color: #444444;
  font-weight: bold;
}

.cart-item-price text {
  font-size: 20rpx;
}

/* Quantity Control - 纤细 */
.cart-qty-control {
  display: flex;
  align-items: center;
}

.cart-qty-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 300;
  transition: background 0.2s ease;
}

.cart-minus-btn {
  background: #F2F2F2;
  color: #888888;
}

.cart-plus-btn {
  background: #EEEEEE;
  color: #333333;
}

.cart-qty-btn:active {
  background: #E0E0E0;
}

.cart-qty-num {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
  min-width: 44rpx;
  text-align: center;
}

/* Delete Button */
.cart-delete-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #C0C0C0;
  font-size: 22rpx;
  margin-left: 16rpx;
  transition: color 0.2s ease;
}

.cart-delete-btn:active {
  color: #888888;
}

/* Bottom Checkout Bar */
.checkout-bar {
  position: fixed;
  bottom: calc(110rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 24rpx 50rpx;
  border-top: 1rpx solid #EEEEEE;
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
}

.checkout-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.checkout-select-all {
  margin-right: 32rpx;
}

.checkout-total {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.total-amount {
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
}

.total-amount text {
  font-size: 22rpx;
}

.total-count {
  font-size: 24rpx;
  color: #888888;
  font-weight: 400;
}

/* 结算按钮 - 高亮有框 */
.checkout-btn {
  background: #7BAF8A;
  color: #FFFFFF;
  border: 2rpx solid #7BAF8A;
  border-radius: 8rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  letter-spacing: 3rpx;
  text-align: center;
  font-weight: 500;
  min-width: 100rpx;
}

.checkout-btn::after {
  border: none;
}

.checkout-btn.disabled {
  background: #F2F2F2;
  color: #C0C0C0;
  border-color: #EEEEEE;
}

/* Batch delete button */
.delete-btn {
  background: #FFFFFF;
  color: #E54D42;
  border: 2rpx solid #E54D42;
  border-radius: 8rpx;
  padding: 16rpx 40rpx;
  font-size: 28rpx;
  letter-spacing: 3rpx;
  text-align: center;
  font-weight: 500;
  min-width: 100rpx;
}

.delete-btn::after {
  border: none;
}

.delete-btn.disabled {
  color: #C0C0C0;
  border-color: #EEEEEE;
}

.manage-selected-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 400;
}

/* Empty State */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-cart-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  color: #E0E0E0;
}

.empty-cart-text {
  font-size: 36rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.empty-cart-subtext {
  font-size: 28rpx;
  color: #888888;
  font-weight: 300;
  margin-bottom: 60rpx;
  letter-spacing: 1rpx;
}

.go-shopping-btn {
  background: transparent;
  color: #7BAF8A;
  border: none;
  border-bottom: 1rpx solid #7BAF8A;
  border-radius: 0;
  padding: 0 20rpx;
  padding-bottom: 4rpx;
  font-size: 28rpx;
  letter-spacing: 3rpx;
  text-align: center;
  font-weight: 400;
}

.go-shopping-btn::after {
  border: none;
}

/* Bottom Spacer */
.bottom-spacer {
  height: 160rpx;
}
