/* pages/cart/cart.wxss */

.cart-page {
  height: 100vh;
  background: #F5F5F5;
}

/* Cart Content */
.cart-content {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* Cart List */
.cart-list {
  flex: 1;
  padding: 16rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: relative;
}

/* Checkbox */
.cart-checkbox {
  padding: 10rpx;
  flex-shrink: 0;
}

.checkbox-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #CCCCCC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #ffffff;
  transition: all 0.2s;
}

.checkbox-icon.checked {
  background: #8B6914;
  border-color: #8B6914;
}

/* Cart Item Image */
.cart-item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin: 0 16rpx;
}

.cart-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-img-real {
  width: 100%;
  height: 100%;
  display: block;
}

.cart-placeholder-text {
  font-size: 48rpx;
  color: rgba(139, 105, 20, 0.2);
  font-weight: bold;
}

/* Cart Item Info */
.cart-item-info {
  flex: 1;
  min-width: 0;
}

.cart-item-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.cart-item-desc {
  display: block;
  font-size: 26rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.cart-item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cart-item-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #E54D42;
}

/* Quantity Control */
.cart-qty-control {
  display: flex;
  align-items: center;
  border: 1rpx solid #EEEEEE;
  border-radius: 8rpx;
  overflow: hidden;
}

.cart-qty-btn {
  width: 60rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  font-size: 34rpx;
  color: #666666;
}

.cart-qty-num {
  min-width: 60rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333333;
  background: #ffffff;
  height: 56rpx;
  line-height: 56rpx;
}

/* Delete Button */
.cart-delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #CCCCCC;
}

/* Bottom Bar */
.cart-bottom-bar {
  display: flex;
  align-items: center;
  background: #ffffff;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #EEEEEE;
  flex-shrink: 0;
}

.select-all {
  display: flex;
  align-items: center;
  padding: 8rpx;
}

.select-all-text {
  font-size: 30rpx;
  color: #333333;
  margin-left: 8rpx;
}

.cart-total {
  flex: 1;
  text-align: right;
  padding-right: 20rpx;
}

.total-label {
  font-size: 28rpx;
  color: #333333;
}

.total-price {
  font-size: 38rpx;
  font-weight: bold;
  color: #E54D42;
}

.checkout-btn {
  background: #8B6914;
  color: #ffffff;
  padding: 24rpx 56rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.checkout-btn.disabled {
  background: #CCCCCC;
}

/* Empty Cart State */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 300rpx;
}

.empty-cart-icon {
  width: 200rpx;
  height: 200rpx;
  background: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon-text {
  font-size: 80rpx;
}

.empty-cart-text {
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.empty-cart-subtext {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 50rpx;
}

.go-shopping-btn {
  background: #8B6914;
  color: #ffffff;
  padding: 20rpx 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}
