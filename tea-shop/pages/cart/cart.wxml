<!-- pages/cart/cart.wxml -->
<view class="cart-page">

  <!-- Cart with items -->
  <view class="cart-content" wx:if="{{cartItems.length > 0}}">

    <!-- Top Checked Summary -->
    <view class="cart-summary-bar">
      <view class="summary-check-icon">
        <text>✓</text>
      </view>
      <text class="summary-text">已选购商品</text>
      <text class="summary-count">（{{totalCount}}件）</text>
      <view class="manage-btn" bindtap="toggleManageMode">
        <text>{{isManageMode ? '完成' : '管理'}}</text>
      </view>
    </view>

    <!-- Cart Item List -->
    <scroll-view class="cart-list" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">
        <!-- Checkbox -->
        <view class="cart-checkbox" bindtap="toggleCheck" data-id="{{item.id}}">
          <view class="checkbox-icon {{item.checked ? 'checked' : ''}}">
            <text wx:if="{{item.checked}}">✓</text>
          </view>
        </view>

        <!-- Product Image -->
        <view class="cart-item-img" bindtap="goToDetail" data-id="{{item.id}}">
          <image wx:if="{{item.image}}" class="cart-img-real" src="{{item.image}}" mode="aspectFill" />
          <view wx:else class="cart-img-placeholder">
            <text class="cart-placeholder-text">{{item.name[0]}}</text>
          </view>
        </view>

        <!-- Product Info -->
        <view class="cart-item-info" bindtap="goToDetail" data-id="{{item.id}}">
          <text class="cart-item-name">{{item.name}}</text>
          <text class="cart-item-desc">{{item.desc}}</text>
          <view class="cart-item-bottom">
            <text class="cart-item-price">¥{{item.price}}</text>
            <view class="cart-qty-control">
              <view class="cart-qty-btn" catchtap="decreaseQty" data-id="{{item.id}}">
                <text>-</text>
              </view>
              <text class="cart-qty-num">{{item.quantity}}</text>
              <view class="cart-qty-btn" catchtap="increaseQty" data-id="{{item.id}}">
                <text>+</text>
              </view>
            </view>
          </view>
        </view>

        <!-- Delete Button -->
        <view class="cart-delete-btn" bindtap="onDeleteItem" data-id="{{item.id}}">
          <text>✕</text>
        </view>
      </view>
    </scroll-view>

    <!-- Bottom Bar - Checkout / Delete -->
    <view class="checkout-bar safe-bottom">
      <view class="checkout-left">
        <view class="checkout-select-all" bindtap="toggleSelectAll">
          <view class="checkbox-icon {{isAllChecked ? 'checked' : ''}}">
            <text wx:if="{{isAllChecked}}">✓</text>
          </view>
        </view>
        <view class="checkout-total">
          <block wx:if="{{!isManageMode}}">
            <text class="total-amount">¥{{totalPrice}}</text>
            <text class="total-count" wx:if="{{totalCount > 0}}">（共{{totalCount}}件）</text>
          </block>
          <block wx:else>
            <text class="manage-selected-text">已选{{selectedCount}}件</text>
          </block>
        </view>
      </view>
      <!-- Checkout button (normal mode) -->
      <view class="checkout-btn {{totalCount === 0 ? 'disabled' : ''}}" bindtap="checkout" wx:if="{{!isManageMode}}">
        <text>结算</text>
      </view>
      <!-- Delete button (manage mode) -->
      <view class="delete-btn {{selectedCount === 0 ? 'disabled' : ''}}" bindtap="batchDelete" wx:else>
        <text>删除</text>
      </view>
    </view>
  </view>

  <!-- Empty Cart State -->
  <view class="empty-cart" wx:if="{{cartItems.length === 0}}">
    <view class="empty-cart-icon">
      <text class="empty-icon-text">🛒</text>
    </view>
    <text class="empty-cart-text">购物车是空的</text>
    <text class="empty-cart-subtext">去逛逛，发现好茶</text>
    <view class="go-shopping-btn" bindtap="goShopping">
      <text>去选购</text>
    </view>
  </view>
</view>
