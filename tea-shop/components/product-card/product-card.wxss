/* components/product-card/product-card.wxss - 清爽极简 */

.product-card {
  background: #F8F8F8;
  border-radius: 8rpx;
  overflow: hidden;
}

.card-img-wrap {
  width: 100%;
  height: 260rpx;
}

.card-img {
  width: 100%;
  height: 100%;
}

.card-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-char {
  font-size: 64rpx;
  color: #E0E0E0;
  font-weight: 300;
}

.card-info {
  padding: 20rpx;
}

.card-name {
  display: block;
  font-size: 28rpx;
  font-weight: 400;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #888888;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 12rpx;
  font-weight: 400;
}

.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-price-row {
  display: flex;
  align-items: baseline;
}

.card-price-symbol {
  font-size: 22rpx;
  color: #444444;
  font-weight: bold;
}

.card-price {
  font-size: 32rpx;
  color: #444444;
  font-weight: bold;
}

.card-qty {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 44rpx;
  height: 44rpx;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 300;
}

.qty-btn.hidden {
  visibility: hidden;
}

.qty-btn.minus {
  background: #F2F2F2;
  color: #888888;
}

.qty-btn.plus {
  background: #EEEEEE;
  color: #333333;
}

.qty-text {
  font-size: 26rpx;
  color: #333333;
  min-width: 40rpx;
  text-align: center;
  font-weight: 500;
}
