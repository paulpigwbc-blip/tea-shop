/* components/cart-item/cart-item.wxss - 清爽极简 */

.cart-item-component {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 0;
  padding: 24rpx 0;
  margin-bottom: 0;
  border-bottom: 1rpx solid #EEEEEE;
  position: relative;
}

/* Checkbox */
.item-checkbox {
  padding: 10rpx;
  flex-shrink: 0;
}

.checkbox-circle {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 1rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #FFFFFF;
}

.checkbox-circle.checked {
  background: #7BAF8A;
  border-color: #7BAF8A;
}

/* Image */
.item-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 6rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin: 0 20rpx;
}

.item-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-img-real {
  width: 100%;
  height: 100%;
}

.item-placeholder-char {
  font-size: 48rpx;
  color: #E0E0E0;
  font-weight: 300;
}

/* Info */
.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  display: block;
  font-size: 28rpx;
  font-weight: 400;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.item-desc {
  display: block;
  font-size: 24rpx;
  color: #888888;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 16rpx;
  font-weight: 400;
}

.item-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.item-price {
  font-size: 30rpx;
  font-weight: bold;
  color: #444444;
}

/* Quantity Control */
.item-qty-control {
  display: flex;
  align-items: center;
  border-radius: 4rpx;
  overflow: hidden;
}

.item-qty-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F2F2F2;
  font-size: 28rpx;
  color: #888888;
  font-weight: 300;
}

.item-qty-num {
  min-width: 44rpx;
  text-align: center;
  font-size: 26rpx;
  color: #333333;
  background: #FFFFFF;
  height: 44rpx;
  line-height: 44rpx;
  font-weight: 500;
}

/* Delete */
.item-delete {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #E0E0E0;
}
