/* app.wxss - Global Styles */
page {
  background-color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Microsoft YaHei', Arial, sans-serif;
  color: #333333;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image, scroll-view {
  box-sizing: border-box;
}

/* Color Variables via CSS Custom Properties */
page {
  --color-primary: #8B6914;
  --color-secondary: #5B7744;
  --color-bg: #FFFFFF;
  --color-bg-gray: #F5F5F5;
  --color-text: #333333;
  --color-text-secondary: #999999;
  --color-price: #E54D42;
  --color-border: #EEEEEE;
  --color-white: #FFFFFF;
  --color-gold: #C4A862;
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  --radius-card: 16rpx;
  --radius-btn: 8rpx;
}

/* Common utility classes */
.container {
  padding: 20rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.price {
  color: #E54D42;
  font-weight: bold;
}

.price-symbol {
  font-size: 26rpx;
}

.price-value {
  font-size: 34rpx;
}

.btn-primary {
  background-color: #8B6914;
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  padding: 22rpx 48rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

/* Common card style */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

/* Safe area for bottom navigation */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* Hide scrollbar */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}
