/* pages/dashboard/dashboard.wxss */

.dashboard-page {
  background: #F5F5F5;
  min-height: 100vh;
}

/* Shop Status Bar */
.shop-status-bar {
  background: linear-gradient(135deg, #1A2818, #3D5232);
  padding: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.shop-info {
  flex: 1;
}

.shop-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 6rpx;
}

.shop-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

.shop-toggle {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
}

.shop-toggle.open {
  background: rgba(91, 119, 68, 0.4);
  color: #A8C090;
}

.shop-toggle.closed {
  background: rgba(229, 77, 66, 0.4);
  color: #FFB0A8;
}

.toggle-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.shop-toggle.open .toggle-dot {
  background: #5B7744;
}

.shop-toggle.closed .toggle-dot {
  background: #E54D42;
}

/* Stats Grid */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 16rpx;
  gap: 12rpx;
}

.stat-card {
  width: 48%;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #999999;
}

.pending-card {
  border-left: 6rpx solid #E54D42;
}

/* Status Overview */
.status-overview {
  background: #ffffff;
  margin: 0 16rpx 16rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.overview-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.overview-grid {
  display: flex;
  justify-content: space-around;
}

.overview-item {
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
}

.overview-item:active {
  background: #F5F5F5;
}

.overview-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin: 0 auto 10rpx;
}

.dot-paid { background: #FF9800; }
.dot-shipped { background: #5B7744; }
.dot-completed { background: #999999; }

.overview-num {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.overview-label {
  font-size: 22rpx;
  color: #999999;
}

/* Recent Orders */
.recent-section {
  background: #ffffff;
  margin: 0 16rpx;
  border-radius: 16rpx;
  padding: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  font-size: 24rpx;
  color: #8B6914;
}

.recent-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-info {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
  gap: 12rpx;
}

.recent-no {
  font-size: 26rpx;
  color: #333333;
  font-weight: 500;
}

.recent-status {
  font-size: 24rpx;
  color: #8B6914;
  font-weight: bold;
}

.recent-time {
  font-size: 22rpx;
  color: #999999;
  margin-left: auto;
}

.recent-bottom {
  display: flex;
  justify-content: space-between;
}

.recent-items {
  font-size: 22rpx;
  color: #999999;
}

.recent-price {
  font-size: 26rpx;
  font-weight: bold;
  color: #E54D42;
}

.recent-empty {
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}

.bottom-spacer {
  height: 120rpx;
}
