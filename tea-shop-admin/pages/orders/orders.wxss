/* pages/orders/orders.wxss */

.orders-page {
  background: #F5F5F5;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.tab-bar {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #EEEEEE;
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #8B6914;
  font-weight: bold;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #8B6914;
  border-radius: 2rpx;
}

.order-scroll {
  flex: 1;
  padding: 16rpx;
}

.order-card {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.order-left {
  flex: 1;
}

.order-no {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 4rpx;
}

.order-time {
  font-size: 26rpx;
  color: #999999;
}

.order-status {
  font-size: 28rpx;
  font-weight: bold;
  color: #8B6914;
  background: rgba(139, 105, 20, 0.08);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.order-items {
  padding: 16rpx 24rpx;
}

.order-product {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.product-name {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.product-qty {
  font-size: 26rpx;
  color: #999999;
  margin-right: 20rpx;
}

.product-price {
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
}

.order-total-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 24rpx;
  background: #FAFAFA;
}

.total-label {
  font-size: 28rpx;
  color: #666666;
}

.total-price {
  font-size: 34rpx;
  font-weight: bold;
  color: #E54D42;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  padding: 16rpx 24rpx;
}

.action-btn {
  padding: 16rpx 36rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.action-btn::after {
  border: none;
}

.btn-accept {
  background: #8B6914;
  color: #ffffff;
}

.btn-prepare {
  background: #5B7744;
  color: #ffffff;
}

.btn-ship {
  background: #C4A862;
  color: #ffffff;
}

.btn-complete {
  background: #999999;
  color: #ffffff;
}

.btn-detail {
  background: #F5F5F5;
  color: #666666;
}

.empty-state {
  padding: 200rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.bottom-spacer {
  height: 120rpx;
}
