/* pages/product-edit/product-edit.wxss */
.edit-page { background: #F5F5F5; min-height: 100vh; padding: 16rpx; }
.form-card { background: #ffffff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.form-item { margin-bottom: 24rpx; }
.form-label { display: block; font-size: 30rpx; color: #333333; font-weight: bold; margin-bottom: 12rpx; }
.form-input { background: #F5F5F5; border-radius: 10rpx; padding: 24rpx; font-size: 30rpx; color: #333333; }
.form-picker { display: flex; justify-content: space-between; align-items: center; background: #F5F5F5; border-radius: 10rpx; padding: 24rpx; font-size: 30rpx; color: #333333; }
.form-picker .placeholder { color: #BBBBBB; }
.picker-arrow { color: #CCCCCC; font-size: 28rpx; }
.form-textarea { background: #F5F5F5; border-radius: 10rpx; padding: 24rpx; font-size: 30rpx; color: #333333; width: 100%; height: 180rpx; }
.save-btn { background: #8B6914; color: #ffffff; text-align: center; padding: 32rpx; border-radius: 12rpx; margin-top: 30rpx; font-size: 34rpx; font-weight: bold; }
.save-btn::after { border: none; }

/* Image Upload Grid */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.img-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.img-preview {
  width: 100%;
  height: 100%;
}

.img-cover-tag {
  position: absolute;
  top: 0;
  left: 0;
  background: #8B6914;
  color: #ffffff;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 0 0 8rpx 0;
}

.img-cover-btn {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 18rpx;
  text-align: center;
  padding: 4rpx 0;
}

.img-delete-btn {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(229, 77, 66, 0.8);
  color: #ffffff;
  border-radius: 0 12rpx 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.img-add-btn {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #CCCCCC;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #CCCCCC;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #CCCCCC;
  margin-top: 6rpx;
}

.image-tip {
  font-size: 26rpx;
  color: #999999;
  margin-top: 12rpx;
}
